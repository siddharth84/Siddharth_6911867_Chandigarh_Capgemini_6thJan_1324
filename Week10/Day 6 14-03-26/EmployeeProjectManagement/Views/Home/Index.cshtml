@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Employee Project Management System</h1>
    <p class="lead">Manage Employees, Projects, and Departments</p>
</div>

<br />

<div class="container">
    <div class="row">

        <div class="col-md-3">
            <div class="card shadow">
                <div class="card-body text-center">
                    <h4 class="card-title">Employees</h4>
                    <p>View and manage employees</p>
                    <a href="/Employees" class="btn btn-primary">View Employees</a>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow">
                <div class="card-body text-center">
                    <h4 class="card-title">Projects</h4>
                    <p>View and manage projects</p>
                    <a href="/Projects" class="btn btn-success">View Projects</a>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow">
                <div class="card-body text-center">
                    <h4 class="card-title">Departments</h4>
                    <p>View department details</p>
                    <a href="/Department" class="btn btn-warning">View Departments</a>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow">
                <div class="card-body text-center">
                    <h4 class="card-title">Dashboard</h4>
                    <p>Project overview dashboard</p>
                    <a href="/Dashboard" class="btn btn-dark">Open Dashboard</a>
                </div>
            </div>
        </div>

    </div>
</div>