@page
@model IndexModel
@{
    ViewData["Title"] = "Event Management";
}

<div class="container mt-4">
    <div id="admin-panel" style="display: none;">
        <div class="card shadow-sm mb-5 border-0 bg-dark text-white p-4">
            <h4>Admin: Create New Event</h4>
            <div class="row g-2">
                <div class="col-md-3"><input type="text" id="addTitle" class="form-control" placeholder="Event Name"></div>
                <div class="col-md-2"><input type="text" id="addLoc" class="form-control" placeholder="Location"></div>
                <div class="col-md-2"><input type="number" id="addSeats" class="form-control" placeholder="Seats"></div>
                <div class="col-md-3"><input type="date" id="addDate" class="form-control"></div>
                <div class="col-md-2"><button class="btn btn-warning w-100" onclick="addNewEvent()">Create</button></div>
            </div>
        </div>
    </div>

    <h2 class="fw-bold mb-4">Available Events</h2>
    <div id="event-list" class="row mb-5"></div>

    <hr />
    <h2 class="fw-bold mt-5 mb-4 text-success">My Booked Events</h2>
    <div id="my-bookings-list" class="row"></div>
</div>

<script>
    const API_URL = "http://localhost:5259/api";

    window.onload = function() {
        const role = localStorage.getItem("userRole");
        if (role === "Admin") document.getElementById("admin-panel").style.display = "block";
        
        loadEvents();
        loadMyBookings(); // Fetch bookings on load
    };

    // 1. Load All Available Events
    async function loadEvents() {
        const res = await fetch(`${API_URL}/events`);
        const data = await res.json();
        document.getElementById("event-list").innerHTML = data.map(e => `
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body">
                        <h5 class="card-title fw-bold text-primary">${e.title}</h5>
                        <p class="small text-muted mb-1">${e.location} | ${new Date(e.date).toLocaleDateString()}</p>
                        <p class="badge bg-success">${e.availableSeats} Left</p>
                        <div class="input-group mt-2">
                            <input type="number" id="qty-${e.id}" class="form-control" value="1" min="1" max="${e.availableSeats}">
                            <button class="btn btn-primary" onclick="book(${e.id}, ${e.availableSeats})">Book</button>
                        </div>
                    </div>
                </div>
            </div>
        `).join('');
    }

    // 2. NEW: Load User Specific Bookings
    async function loadMyBookings() {
        const container = document.getElementById("my-bookings-list");
        const token = localStorage.getItem("token");

        if (!token) {
            container.innerHTML = "<p class='text-muted'>Login to see your history.</p>";
            return;
        }

        try {
            const res = await fetch(`${API_URL}/bookings/my-bookings`, {
                headers: { "Authorization": "Bearer " + token }
            });
            const data = await res.json();

            if (data.length === 0) {
                container.innerHTML = "<p>No bookings found.</p>";
                return;
            }

            container.innerHTML = data.map(b => `
                <div class="col-md-4 mb-3">
                    <div class="card border-success shadow-sm">
                        <div class="card-body">
                            <h6 class="fw-bold">${b.eventTitle}</h6>
                            <p class="small text-muted mb-2">Date: ${new Date(b.eventDate).toLocaleDateString()}</p>
                            <div class="d-flex justify-content-between">
                                <span class="badge bg-primary">${b.seatsReserved} Seats</span>
                                <button class="btn btn-sm btn-danger" onclick="cancelBooking(${b.bookingId})">Cancel</button>
                            </div>
                        </div>
                    </div>
                </div>
            `).join('');
        } catch (err) { console.error(err); }
    }

    // 3. Book Event
    async function book(eventId, available) {
        const qty = parseInt(document.getElementById(`qty-${eventId}`).value);
        const token = localStorage.getItem("token");

        if (!token) return alert("Login first!");
        if (qty > available) return alert("Not enough seats!");

        const res = await fetch(`${API_URL}/bookings`, {
            method: "POST",
            headers: { "Content-Type": "application/json", "Authorization": "Bearer " + token },
            body: JSON.stringify({ eventId, seatsBooked: qty })
        });

        if (res.ok) {
            alert("Success!");
            loadEvents();
            loadMyBookings();
        }
    }

    // 4. NEW: Cancel Booking
    async function cancelBooking(id) {
        if (!confirm("Cancel this booking?")) return;
        const token = localStorage.getItem("token");

        const res = await fetch(`${API_URL}/bookings/${id}`, {
            method: "DELETE",
            headers: { "Authorization": "Bearer " + token }
        });

        if (res.ok) {
            alert("Cancelled!");
            loadEvents();
            loadMyBookings();
        }
    }

    async function addNewEvent() {
        const payload = {
            title: document.getElementById("addTitle").value,
            location: document.getElementById("addLoc").value,
            availableSeats: parseInt(document.getElementById("addSeats").value),
            date: new Date(document.getElementById("addDate").value).toISOString(),
            description: "Admin Entry"
        };
        const res = await fetch(`${API_URL}/events`, {
            method: "POST",
            headers: { "Content-Type": "application/json", "Authorization": "Bearer " + localStorage.getItem("token") },
            body: JSON.stringify(payload)
        });
        if (res.ok) { alert("Event Added!"); loadEvents(); }
    }
</script>