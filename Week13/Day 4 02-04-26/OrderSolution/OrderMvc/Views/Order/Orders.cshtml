@using System.Text.Json
@model List<JsonElement>
@{
    ViewData["Title"] = "All Orders";
}

<div class="card">
    <h2>📋 All Orders</h2>

    @if (ViewBag.Error != null)
    {
        <div class="alert-danger">@ViewBag.Error</div>
    }
    else if (Model == null || !Model.Any())
    {
        <p style="color:#888">No orders yet. <a href="/Order/Create">Place one!</a></p>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Order ID</th>
                    <th>User ID</th>
                    <th>Date</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td>#@order.GetProperty("id").GetInt32()</td>
                        <td>@order.GetProperty("userId").GetInt32()</td>
                        <td>@order.GetProperty("orderDate").GetDateTime().ToString("dd MMM yyyy, HH:mm")</td>
                        <td>
                            <span class="badge badge-user">
                                @order.GetProperty("status").GetString()
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <div style="margin-top:24px">
        <a href="/Order/Create" class="btn btn-primary">Place New Order</a>
    </div>
</div>
