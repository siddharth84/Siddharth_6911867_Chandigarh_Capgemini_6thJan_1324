@{
    ViewData["Title"] = "Login";
}

<div class="card" style="max-width:480px; margin:0 auto">
    <h2>🔐 Login</h2>
    <p style="color:#666; margin-bottom:24px; font-size:14px">
        Use <strong>user / user123</strong> to place orders, or <strong>admin / admin123</strong> to add products.
    </p>

    @if (ViewBag.Error != null)
    {
        <div class="alert-danger">@ViewBag.Error</div>
    }

    <form method="post">
        <div class="form-group">
            <label>Username</label>
            <input type="text" name="username" placeholder="e.g. user" required />
        </div>
        <div class="form-group">
            <label>Password</label>
            <input type="password" name="password" placeholder="e.g. user123" required />
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%">Login &amp; Continue</button>
    </form>
</div>
