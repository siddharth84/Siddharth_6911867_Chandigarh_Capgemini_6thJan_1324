@using System.Text.Json
@{
    ViewData["Title"] = "Products";
    var source   = ViewBag.Source as string ?? "unknown";
    var products = (JsonElement)ViewBag.Products;
}

<div class="card">
    <h2>🛍️ Products</h2>
    <p style="color:#888; font-size:13px; margin-bottom:20px">
        Source: <strong>@source</strong>
        — @(source == "cache (fast!)" ? "✅ Served from memory cache (fast!)" : "🗄️ Fetched from database and now cached for 5 minutes")
    </p>

    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Price</th>
                <th>Stock</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in products.EnumerateArray())
            {
                <tr>
                    <td>#@p.GetProperty("Id").GetInt32()</td>
                    <td>@p.GetProperty("Name").GetString()</td>
                    <td>$@p.GetProperty("Price").GetDecimal().ToString("F2")</td>
                    <td>@p.GetProperty("Stock").GetInt32() units</td>
                </tr>
            }
        </tbody>
    </table>

    <div style="margin-top:24px">
        <a href="/Order/Products" class="btn btn-primary">Refresh (check cache)</a>
        &nbsp;
        <a href="/Order/Login" class="btn btn-success">Login to Place Order</a>
    </div>
</div>
