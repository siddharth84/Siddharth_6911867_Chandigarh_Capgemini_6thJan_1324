@{
    ViewData["Title"] = "Place Order";
    var token    = ViewBag.Token as string ?? "";
    var role     = ViewBag.Role as string ?? "";
    var username = ViewBag.Username as string ?? "";
}

<div class="card" style="max-width:560px; margin:0 auto">
    <h2>📦 Place an Order</h2>

    @if (!string.IsNullOrEmpty(username))
    {
        <div class="alert-success">
            Logged in as <strong>@username</strong>
            <span class="badge @(role == "Admin" ? "badge-admin" : "badge-user")">@role</span>
        </div>
    }

    @if (role == "Admin")
    {
        <div class="alert-danger">
            ⚠️ Admin accounts cannot place orders — only <strong>User</strong> accounts can.
            <br /><a href="/Order/Login">Login as user / user123 instead</a>
        </div>
    }

    @if (ViewBag.Error != null)
    {
        <div class="alert-danger">@ViewBag.Error</div>
    }

    <form method="post">
        <input type="hidden" name="token" value="@token" />

        <div class="form-group">
            <label>User ID (1 = Alice, 2 = Bob — seeded in the database)</label>
            <input type="number" name="userId" value="1" min="1" required />
        </div>

        <div style="background:#f9f9f9; border-radius:8px; padding:14px; margin-bottom:20px; font-size:12px; color:#888; word-break:break-all">
            <strong>Your JWT Token:</strong><br />@token
        </div>

        <div style="display:flex; gap:12px">
            <button type="submit" class="btn btn-primary" @(role == "Admin" ? "disabled" : "")>
                Place Order
            </button>
            <a href="/Order/Orders?token=@token" class="btn btn-success">View All Orders</a>
            <a href="/Order/Login" class="btn" style="background:#eee; color:#333">Switch User</a>
        </div>
    </form>
</div>
