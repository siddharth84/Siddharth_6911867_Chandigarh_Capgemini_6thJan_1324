@{
    ViewData["Title"] = "Home";
}

<div class="card">
    <h2>Welcome to the Order Management System</h2>
    <p style="color:#666; margin-bottom:28px; line-height:1.7">
        This is a learning project demonstrating ASP.NET Core Web API + MVC, 
        Dependency Injection, JWT Authentication, Repository Pattern, EF Core, AutoMapper, and FluentValidation.
    </p>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:28px">
        <div style="background:#f5f7ff; border-radius:10px; padding:20px">
            <div style="font-size:24px; margin-bottom:8px">🔐</div>
            <strong>Two test accounts</strong>
            <p style="font-size:13px; color:#666; margin-top:6px; line-height:1.6">
                <b>user / user123</b> — can place orders<br>
                <b>admin / admin123</b> — can add products
            </p>
        </div>
        <div style="background:#f5f7ff; border-radius:10px; padding:20px">
            <div style="font-size:24px; margin-bottom:8px">📦</div>
            <strong>What this app does</strong>
            <p style="font-size:13px; color:#666; margin-top:6px; line-height:1.6">
                Login → get JWT token → place orders → view order history
            </p>
        </div>
        <div style="background:#f5f7ff; border-radius:10px; padding:20px">
            <div style="font-size:24px; margin-bottom:8px">🗄️</div>
            <strong>Database</strong>
            <p style="font-size:13px; color:#666; margin-top:6px; line-height:1.6">
                SQL Server LocalDB with Users, Orders, Products, Categories (seeded automatically)
            </p>
        </div>
        <div style="background:#f5f7ff; border-radius:10px; padding:20px">
            <div style="font-size:24px; margin-bottom:8px">📄</div>
            <strong>API Docs</strong>
            <p style="font-size:13px; color:#666; margin-top:6px; line-height:1.6">
                Swagger UI available at the API's root URL for testing all endpoints directly
            </p>
        </div>
    </div>

    <a href="/Order/Login" class="btn btn-primary">Get Started — Login</a>
    &nbsp;
    <a href="/Order/Products" class="btn btn-success">View Products</a>
</div>
