@model SmartHealthcare.Models.DTOs.CreateDoctorDTO
@{
    ViewData["Title"] = "Complete Doctor Profile";
    var specializations = ViewBag.Specializations as IEnumerable<SmartHealthcare.Models.DTOs.SpecializationDTO> ?? Enumerable.Empty<SmartHealthcare.Models.DTOs.SpecializationDTO>();
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-lg">
                <div class="card-header bg-info text-white p-4">
                    <h3 class="mb-0"><i class="bi bi-person-plus"></i> Complete Your Doctor Profile</h3>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted mb-4">Please complete your doctor profile so patients can book appointments with you.</p>

                    <form asp-action="CreateProfile" method="post" novalidate>
                        <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="LicenseNumber" class="form-label fw-bold">License Number *</label>
                            <input asp-for="LicenseNumber" class="form-control form-control-lg" />
                            <span asp-validation-for="LicenseNumber" class="text-danger small"></span>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="YearsOfExperience" class="form-label fw-bold">Years of Experience *</label>
                                <input asp-for="YearsOfExperience" class="form-control form-control-lg" type="number" min="0" max="60" />
                                <span asp-validation-for="YearsOfExperience" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ConsultationFee" class="form-label fw-bold">Consultation Fee (Rs) *</label>
                                <input asp-for="ConsultationFee" class="form-control form-control-lg" type="number" step="0.01" min="0" />
                                <span asp-validation-for="ConsultationFee" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3 mt-3">
                            <label asp-for="Phone" class="form-label fw-bold">Phone *</label>
                            <input asp-for="Phone" class="form-control form-control-lg" />
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Specializations *</label>
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var spec in specializations)
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="SpecializationIds" value="@spec.Id" id="spec-@spec.Id" />
                                        <label class="form-check-label" for="spec-@spec.Id">@spec.Name</label>
                                    </div>
                                }
                            </div>
                            <span asp-validation-for="SpecializationIds" class="text-danger small"></span>
                        </div>

                        <div class="mb-4 form-check form-switch">
                            <input asp-for="IsAvailable" class="form-check-input" type="checkbox" id="IsAvailable" />
                            <label class="form-check-label" for="IsAvailable">Available for appointments</label>
                        </div>

                        <div class="d-grid gap-2 d-sm-flex justify-content-sm-between">
                            <button type="submit" class="btn btn-info btn-lg"><i class="bi bi-check-circle"></i> Create Profile</button>
                            <a href="@Url.Action("Index", "Doctor")" class="btn btn-outline-secondary btn-lg"><i class="bi bi-x-circle"></i> Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
