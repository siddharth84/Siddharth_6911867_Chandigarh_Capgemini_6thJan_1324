@{
    ViewData["Title"] = "Dashboard";
    var role = ViewBag.Role as string;
    var fullName = ViewBag.FullName as string;
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="jumbotron bg-light p-4 rounded">
                <h1 class="display-4">Welcome, <strong>@fullName</strong>! 👋</h1>
                <p class="lead">You're logged in as: <span class="badge bg-info">@role</span></p>
                <hr class="my-4">
                <p>Smart Healthcare Management System - Your gateway to quality healthcare</p>
            </div>
        </div>
    </div>

    @if (role == "Admin")
    {
        <div class="row mb-4">
            <div class="col-md-3 mb-3">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body bg-primary text-white">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-title text-white-50">USERS</h6>
                                <h3 class="mb-0">-</h3>
                            </div>
                            <i class="bi bi-people fs-1 text-white-50"></i>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent">
                        <a href="@Url.Action("Users", "Admin")" class="btn btn-sm btn-primary w-100">Manage Users</a>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-3">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body bg-success text-white">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-title text-white-50">DOCTORS</h6>
                                <h3 class="mb-0">-</h3>
                            </div>
                            <i class="bi bi-hospital fs-1 text-white-50"></i>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent">
                        <a href="@Url.Action("Index", "Doctor")" class="btn btn-sm btn-success w-100">View Doctors</a>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-3">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body bg-warning text-dark">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-title">PATIENTS</h6>
                                <h3 class="mb-0">-</h3>
                            </div>
                            <i class="bi bi-person-check fs-1"></i>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent">
                        <a href="@Url.Action("Index", "Appointment")" class="btn btn-sm btn-warning w-100">View Patients</a>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-3">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body bg-danger text-white">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="card-title text-white-50">APPOINTMENTS</h6>
                                <h3 class="mb-0">-</h3>
                            </div>
                            <i class="bi bi-calendar-check fs-1 text-white-50"></i>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent">
                        <a href="@Url.Action("Index", "Appointment")" class="btn btn-sm btn-danger w-100">View All</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-12">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-dark text-white">
                        <h5 class="mb-0"><i class="bi bi-graph-up"></i> Admin Reports</h5>
                    </div>
                    <div class="card-body">
                        <div class="text-center py-5">
                            <p class="text-muted">Reports data will be displayed here</p>
                            <a href="@Url.Action("Reports", "Admin")" class="btn btn-dark">View Detailed Reports</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (role == "Doctor")
    {
        <div class="row mb-4">
            <div class="col-md-4 mb-3">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body bg-info text-white">
                        <h5 class="card-title text-white-50">MY APPOINTMENTS</h5>
                        <p class="card-text display-6">View Schedule</p>
                    </div>
                    <div class="card-footer bg-transparent">
                        <a href="@Url.Action("Index", "Appointment")" class="btn btn-info w-100">Go to Appointments</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-3">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body bg-secondary text-white">
                        <h5 class="card-title text-white-50">MY PROFILE</h5>
                        <p class="card-text display-6">Update Info</p>
                    </div>
                    <div class="card-footer bg-transparent">
                        <a href="@Url.Action("Profile", "Patient")" class="btn btn-secondary w-100">Edit Profile</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-3">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body bg-warning text-dark">
                        <h5 class="card-title">PRESCRIPTIONS</h5>
                        <p class="card-text display-6">Manage Rx</p>
                    </div>
                    <div class="card-footer bg-transparent">
                        <a href="javascript:void(0)" class="btn btn-warning w-100">View Prescriptions</a>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (role == "Patient")
    {
        <div class="row mb-4">
            <div class="col-md-4 mb-3">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body bg-success text-white">
                        <h5 class="card-title text-white-50">BOOK APPOINTMENT</h5>
                        <p class="card-text">Schedule a visit with a doctor</p>
                    </div>
                    <div class="card-footer bg-transparent">
                        <a href="@Url.Action("Create", "Appointment")" class="btn btn-success w-100">Book Now</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-3">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body bg-info text-white">
                        <h5 class="card-title text-white-50">MY APPOINTMENTS</h5>
                        <p class="card-text">View your schedule</p>
                    </div>
                    <div class="card-footer bg-transparent">
                        <a href="@Url.Action("Index", "Appointment")" class="btn btn-info w-100">View All</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-3">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body bg-warning text-dark">
                        <h5 class="card-title">MY PROFILE</h5>
                        <p class="card-text">Update your info</p>
                    </div>
                    <div class="card-footer bg-transparent">
                        <a href="@Url.Action("Profile", "Patient")" class="btn btn-warning w-100">Edit Profile</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-12 mb-4">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="bi bi-stethoscope"></i> Browse Our Doctors</h5>
                    </div>
                    <div class="card-body">
                        <p class="card-text">Looking for an experienced doctor? Browse our network of qualified healthcare professionals.</p>
                        <a href="@Url.Action("Index", "Doctor")" class="btn btn-primary"><i class="bi bi-search"></i> Find a Doctor</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .jumbotron {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-radius: 2rem;
        padding: 3rem;
        margin-bottom: 2rem;
        position: relative;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
        animation: jumbotronSlideIn 1s ease-out;
    }

    .jumbotron::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
        animation: rotate 25s linear infinite;
    }

    @@keyframes rotate {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    @@keyframes jumbotronSlideIn {
        from {
            opacity: 0;
            transform: translateY(50px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .jumbotron h1 {
        font-weight: 800;
        text-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
        background: linear-gradient(135deg, #ffffff, #e0e7ff);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .badge {
        background: rgba(255, 255, 255, 0.2) !important;
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 2rem;
        padding: 0.5rem 1rem;
        font-weight: 600;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
    }

    .card {
        border: none;
        border-radius: 1.5rem;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        backdrop-filter: blur(15px);
        background: rgba(255, 255, 255, 0.95);
        transition: all 0.4s ease;
        overflow: hidden;
        position: relative;
        animation: cardFadeIn 0.8s ease-out;
    }

    .card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, var(--card-color), var(--card-color-dark));
    }

    @@keyframes cardFadeIn {
        from {
            opacity: 0;
            transform: translateY(30px) scale(0.95);
        }
        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    .card:nth-child(1) { animation-delay: 0.1s; --card-color: #0d6efd; --card-color-dark: #6610f2; }
    .card:nth-child(2) { animation-delay: 0.2s; --card-color: #198754; --card-color-dark: #155724; }
    .card:nth-child(3) { animation-delay: 0.3s; --card-color: #ffc107; --card-color-dark: #e0a800; }
    .card:nth-child(4) { animation-delay: 0.4s; --card-color: #dc3545; --card-color-dark: #c82333; }

    .card:hover {
        transform: translateY(-8px) scale(1.02);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
    }

    .card-body {
        padding: 2rem;
        position: relative;
        z-index: 1;
    }

    .card-body.bg-primary {
        background: linear-gradient(135deg, rgba(13, 110, 253, 0.9), rgba(102, 16, 242, 0.9)) !important;
        color: white;
    }

    .card-body.bg-success {
        background: linear-gradient(135deg, rgba(25, 135, 84, 0.9), rgba(21, 87, 36, 0.9)) !important;
        color: white;
    }

    .card-body.bg-warning {
        background: linear-gradient(135deg, rgba(255, 193, 7, 0.9), rgba(224, 168, 0, 0.9)) !important;
        color: #212529;
    }

    .card-body.bg-danger {
        background: linear-gradient(135deg, rgba(220, 53, 69, 0.9), rgba(200, 35, 51, 0.9)) !important;
        color: white;
    }

    .card-title {
        font-weight: 700;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        opacity: 0.9;
        margin-bottom: 0.5rem;
    }

    .card-body h3 {
        font-weight: 800;
        font-size: 2.5rem;
        margin: 0.5rem 0;
        text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
    }

    .card-footer {
        background: rgba(255, 255, 255, 0.1);
        border-top: 1px solid rgba(255, 255, 255, 0.2);
        padding: 1.5rem;
    }

    .btn {
        border-radius: 2rem;
        padding: 0.5rem 1.5rem;
        font-weight: 600;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .btn::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
        transition: left 0.5s;
    }

    .btn:hover::before {
        left: 100%;
    }

    .btn-primary {
        background: linear-gradient(135deg, #0d6efd, #6610f2);
        border: none;
        box-shadow: 0 4px 15px rgba(13, 110, 253, 0.3);
    }

    .btn-primary:hover {
        background: linear-gradient(135deg, #6610f2, #0d6efd);
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(13, 110, 253, 0.4);
    }

    .btn-success {
        background: linear-gradient(135deg, #198754, #155724);
        border: none;
        box-shadow: 0 4px 15px rgba(25, 135, 84, 0.3);
    }

    .btn-success:hover {
        background: linear-gradient(135deg, #155724, #0f5132);
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(25, 135, 84, 0.4);
    }

    .btn-warning {
        background: linear-gradient(135deg, #ffc107, #e0a800);
        border: none;
        box-shadow: 0 4px 15px rgba(255, 193, 7, 0.3);
    }

    .btn-warning:hover {
        background: linear-gradient(135deg, #e0a800, #d39e00);
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(255, 193, 7, 0.4);
    }

    .btn-danger {
        background: linear-gradient(135deg, #dc3545, #c82333);
        border: none;
        box-shadow: 0 4px 15px rgba(220, 53, 69, 0.3);
    }

    .btn-danger:hover {
        background: linear-gradient(135deg, #c82333, #bd2130);
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(220, 53, 69, 0.4);
    }

    .btn-info {
        background: linear-gradient(135deg, #0dcaf0, #0aa2c0);
        border: none;
        box-shadow: 0 4px 15px rgba(13, 202, 240, 0.3);
    }

    .btn-info:hover {
        background: linear-gradient(135deg, #0aa2c0, #0987a0);
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(13, 202, 240, 0.4);
    }

    .btn-secondary {
        background: linear-gradient(135deg, #6c757d, #545b62);
        border: none;
        box-shadow: 0 4px 15px rgba(108, 117, 125, 0.3);
    }

    .btn-secondary:hover {
        background: linear-gradient(135deg, #545b62, #495057);
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(108, 117, 125, 0.4);
    }

    .card.shadow-sm.border-0 {
        background: linear-gradient(135deg, rgba(248, 250, 252, 0.9), rgba(241, 245, 249, 0.9));
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.2) !important;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1) !important;
    }

    .card-header {
        background: linear-gradient(135deg, #0d6efd, #6610f2);
        color: white;
        border: none;
        padding: 2rem;
        position: relative;
    }

    .card-header::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
    }

    .card-header h5 {
        position: relative;
        z-index: 1;
        margin: 0;
        font-weight: 700;
        text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
    }

    .text-center.py-5 {
        padding: 3rem 2rem !important;
    }

    .btn-dark {
        background: linear-gradient(135deg, #343a40, #212529);
        border: none;
        border-radius: 2rem;
        padding: 0.75rem 2rem;
        font-weight: 600;
        box-shadow: 0 4px 15px rgba(52, 58, 64, 0.3);
        transition: all 0.3s ease;
    }

    .btn-dark:hover {
        background: linear-gradient(135deg, #212529, #343a40);
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(52, 58, 64, 0.4);
    }

    /* Icon enhancements */
    .bi, .fs-1 {
        filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.3));
        transition: all 0.3s ease;
    }

    .bi:hover, .fs-1:hover {
        transform: scale(1.1);
    }

    /* Responsive adjustments */
    @@media (max-width: 768px) {
        .jumbotron {
            padding: 2rem 1.5rem;
            border-radius: 1.5rem;
        }

        .card-body {
            padding: 1.5rem;
        }

        .card-body h3 {
            font-size: 2rem;
        }
    }
</style>