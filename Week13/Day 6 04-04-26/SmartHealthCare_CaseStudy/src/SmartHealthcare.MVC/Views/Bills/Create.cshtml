@model SmartHealthcare.Models.DTOs.CreateBillDTO

@{
    ViewData["Title"] = "Create Bill";
}

<h2>Create Bill for Appointment @ViewBag.AppointmentId</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <input type="hidden" asp-for="AppointmentId" value="@ViewBag.AppointmentId" />

    <div class="form-group">
        <label asp-for="ConsultationFee" class="control-label"></label>
        <input asp-for="ConsultationFee" class="form-control" type="number" step="0.01" />
        <span asp-validation-for="ConsultationFee" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="MedicineCharges" class="control-label"></label>
        <input asp-for="MedicineCharges" class="form-control" type="number" step="0.01" />
        <span asp-validation-for="MedicineCharges" class="text-danger"></span>
    </div>

    <div class="form-group">
        <input type="submit" value="Create Bill" class="btn btn-primary" />
        <a asp-action="Index" asp-controller="Appointment" class="btn btn-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}