@model SmartHealthcare.Models.DTOs.BillDTO

@{
    ViewData["Title"] = "Bill Details";
}

<h2>Bill Details</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="row">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-4">Bill ID</dt>
            <dd class="col-sm-8">@Model.BillId</dd>

            <dt class="col-sm-4">Appointment ID</dt>
            <dd class="col-sm-8">@Model.AppointmentId</dd>

            <dt class="col-sm-4">Consultation Fee</dt>
            <dd class="col-sm-8">$@Model.ConsultationFee.ToString("F2")</dd>

            <dt class="col-sm-4">Medicine Charges</dt>
            <dd class="col-sm-8">$@Model.MedicineCharges.ToString("F2")</dd>

            <dt class="col-sm-4">Total Amount</dt>
            <dd class="col-sm-8">$@Model.TotalAmount.ToString("F2")</dd>

            <dt class="col-sm-4">Payment Status</dt>
            <dd class="col-sm-8">@Model.PaymentStatus</dd>
        </dl>
    </div>
</div>

@if (Context.Session.GetString("Role") == "Admin")
{
    <form asp-action="UpdateStatus" method="post" class="mt-3">
        <input type="hidden" name="id" value="@Model.BillId" />
        <div class="form-group">
            <label for="status">Update Status</label>
            <select name="status" class="form-control" style="width: auto; display: inline-block;">
                <option value="Unpaid" selected="@(Model.PaymentStatus == "Unpaid")">Unpaid</option>
                <option value="Paid" selected="@(Model.PaymentStatus == "Paid")">Paid</option>
                <option value="Cancelled" selected="@(Model.PaymentStatus == "Cancelled")">Cancelled</option>
            </select>
            <input type="submit" value="Update" class="btn btn-primary ml-2" />
        </div>
    </form>
}

<a asp-action="Index" asp-controller="Appointment" class="btn btn-secondary">Back to Appointments</a>