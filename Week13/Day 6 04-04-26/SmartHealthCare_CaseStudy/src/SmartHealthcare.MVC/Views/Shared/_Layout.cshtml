<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0f172a" />
    <title>@ViewData["Title"] - Smart Healthcare</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        :root {
            --navbar-gradient-start: rgba(15, 23, 42, 0.96);
            --navbar-gradient-end: rgba(15, 118, 110, 0.88);
            --accent-primary: #667eea;
            --accent-secondary: #764ba2;
        }

        /* Enhanced Navbar Styling */
        .app-navbar {
            position: sticky;
            top: 0;
            z-index: 1030;
            backdrop-filter: blur(20px);
            background: linear-gradient(135deg, var(--navbar-gradient-start) 0%, var(--navbar-gradient-end) 100%);
            box-shadow: 0 12px 50px rgba(15, 23, 42, 0.25);
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            animation: navbarSlideDown 0.6s ease-out;
        }

        @@keyframes navbarSlideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .navbar-brand {
            font-size: 1.35rem;
            font-weight: 700;
            background: linear-gradient(135deg, #ffffff 0%, #e2e8f0 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            letter-spacing: -0.02em;
            transition: all 0.3s ease;
        }

        .navbar-brand:hover {
            transform: scale(1.05);
            filter: drop-shadow(0 4px 12px rgba(255, 255, 255, 0.2));
        }

        .brand-mark {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 2.5rem;
            height: 2.5rem;
            border-radius: 1rem;
            background: linear-gradient(135deg, rgba(102, 126, 234, 0.3) 0%, rgba(118, 75, 162, 0.3) 100%);
            color: #fff;
            box-shadow: 0 8px 20px rgba(102, 126, 234, 0.2);
            transition: all 0.3s ease;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .brand-mark:hover {
            background: linear-gradient(135deg, rgba(102, 126, 234, 0.5) 0%, rgba(118, 75, 162, 0.5) 100%);
            transform: scale(1.1) rotate(5deg);
            box-shadow: 0 12px 30px rgba(102, 126, 234, 0.3);
        }

        .navbar .nav-link {
            color: rgba(255, 255, 255, 0.85) !important;
            font-weight: 500;
            transition: all 0.3s ease;
            position: relative;
            padding: 0.5rem 1rem !important;
            border-radius: 8px;
        }

        .navbar .nav-link::before {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            width: 0;
            height: 2px;
            background: linear-gradient(90deg, var(--accent-primary), var(--accent-secondary));
            transform: translateX(-50%);
            transition: width 0.3s ease;
        }

        .navbar .nav-link:hover {
            color: #fff !important;
            background: rgba(255, 255, 255, 0.1);
            transform: translateY(-2px);
        }

        .navbar .nav-link:hover::before {
            width: calc(100% - 2rem);
        }

        .navbar-text {
            color: rgba(255, 255, 255, 0.8) !important;
            font-weight: 500;
            animation: fadeInRight 0.6s ease-out 0.2s both;
        }

        .btn-outline-light {
            border: 2px solid rgba(255, 255, 255, 0.4);
            background: rgba(255, 255, 255, 0.05);
            color: #fff;
            font-weight: 600;
            border-radius: 25px;
            padding: 0.5rem 1.2rem;
            transition: all 0.3s ease;
            backdrop-filter: blur(10px);
        }

        .btn-outline-light:hover {
            background: rgba(255, 255, 255, 0.15);
            border-color: rgba(255, 255, 255, 0.6);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(255, 255, 255, 0.2);
        }

        .btn-light {
            background: linear-gradient(135deg, #ffffff 0%, #f1f5f9 100%);
            color: #0f172a;
            border: none;
            font-weight: 600;
            border-radius: 25px;
            padding: 0.5rem 1.2rem;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(255, 255, 255, 0.3);
        }

        .btn-light:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(255, 255, 255, 0.4);
            background: linear-gradient(135deg, #f1f5f9 0%, #ffffff 100%);
        }

        @@keyframes fadeInRight {
            from {
                opacity: 0;
                transform: translateX(20px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        /* Enhanced Main Content Area */
        .main-shell {
            position: relative;
            z-index: 1;
            animation: fadeIn 0.8s ease-out 0.2s both;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
            }
            to {
                opacity: 1;
            }
        }

        /* Enhanced Alerts */
        .alert {
            border-radius: 1.5rem;
            border: none;
            animation: slideInAlert 0.5s ease-out;
            backdrop-filter: blur(10px);
        }

        @@keyframes slideInAlert {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .alert-success {
            background: linear-gradient(135deg, rgba(52, 211, 153, 0.15) 0%, rgba(16, 185, 129, 0.1) 100%);
            border-left: 4px solid #34d399;
            color: #065f46;
        }

        .alert-danger {
            background: linear-gradient(135deg, rgba(248, 113, 113, 0.15) 0%, rgba(239, 68, 68, 0.1) 100%);
            border-left: 4px solid #f87171;
            color: #7f1d1d;
        }

        /* Enhanced Footer */
        .app-footer {
            margin-top: 4rem;
            padding: 2.5rem 0 2rem;
            background: linear-gradient(180deg, rgba(15, 23, 42, 0.8) 0%, rgba(15, 118, 110, 0.6) 100%);
            color: rgba(255, 255, 255, 0.8);
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(15px);
            position: relative;
            overflow: hidden;
            animation: slideInUp 0.8s ease-out;
        }

        @@keyframes slideInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .app-footer::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.05), transparent);
            animation: shimmer 3s infinite;
            pointer-events: none;
        }

        @@keyframes shimmer {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(100%); }
        }

        .app-footer .container {
            padding-top: 1.5rem;
            border-top: 1px solid rgba(255, 255, 255, 0.15);
            position: relative;
            z-index: 1;
        }

        .app-footer span {
            font-weight: 500;
            transition: all 0.3s ease;
        }

        .app-footer span:first-child {
            background: linear-gradient(90deg, #fff 0%, #e2e8f0 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .app-footer span:nth-child(2) {
            color: rgba(255, 255, 255, 0.7);
            font-style: italic;
        }

        .app-footer:hover span {
            filter: brightness(1.1);
        }

        /* Navbar Responsive */
        @@media (max-width: 991.98px) {
            .app-navbar {
                padding: 0.5rem 0;
            }

            .navbar-toggler {
                border-color: rgba(255, 255, 255, 0.3);
                transition: all 0.3s ease;
            }

            .navbar-toggler:hover {
                background: rgba(255, 255, 255, 0.1);
                border-color: rgba(255, 255, 255, 0.6);
            }

            .navbar-brand {
                font-size: 1.2rem;
            }

            .btn-outline-light, .btn-light {
                width: 100%;
                margin-top: 0.5rem;
            }
        }

        /* Footer Responsive */
        @@media (max-width: 767.98px) {
            .app-footer .container {
                text-align: center;
                gap: 1rem;
            }

            .app-footer span {
                display: block;
            }
        }
    </style>
</head>
<body>
    <div class="app-background"></div>
    <nav class="navbar navbar-expand-lg navbar-dark app-navbar">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2 fw-bold" asp-controller="Home" asp-action="Index">
                <span class="brand-mark"><i class="fa-solid fa-hospital"></i></span>
                <span>Smart Healthcare</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navBar" aria-controls="navBar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navBar">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Doctor" asp-action="Index">Doctors</a></li>
                    @if (Context.Session.GetString("Token") != null)
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Appointment" asp-action="Index">Appointments</a></li>
                        @if (Context.Session.GetString("Role") == "Doctor")
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Doctor" asp-action="Profile">Profile</a></li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Patient" asp-action="Profile">Profile</a></li>
                        }
                    }
                </ul>
                <div class="d-flex align-items-lg-center gap-2 ms-lg-auto flex-column flex-lg-row">
                    @if (Context.Session.GetString("Token") != null)
                    {
                        <span class="navbar-text text-white-50 small text-lg-end">@Context.Session.GetString("FullName")</span>
                        <a class="btn btn-outline-light btn-sm" asp-controller="Account" asp-action="Logout">Logout</a>
                    }
                    else
                    {
                        <a class="btn btn-outline-light btn-sm" asp-controller="Account" asp-action="Login">Login</a>
                        <a class="btn btn-light btn-sm" asp-controller="Account" asp-action="Register">Register</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <main class="main-shell">
        <div class="container py-4 py-lg-5">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success shadow-sm border-0">@TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger shadow-sm border-0">@TempData["Error"]</div>
            }
            @RenderBody()
        </div>
    </main>

    <footer class="app-footer">
        <div class="container d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2">
            <span>&copy; 2026 Smart Healthcare</span>
            <span class="text-white-50">Manage care, appointments, and records in one place.</span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
