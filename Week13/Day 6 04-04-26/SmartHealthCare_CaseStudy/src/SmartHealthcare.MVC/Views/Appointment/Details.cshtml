@model SmartHealthcare.Models.DTOs.AppointmentDTO
@{
    ViewData["Title"] = "Appointment Details";
    var prescription = ViewBag.Prescription as SmartHealthcare.Models.DTOs.PrescriptionDTO;
}

<div class="container mt-4">
    <a href="@Url.Action("Index")" class="btn btn-outline-secondary mb-3"><i class="bi bi-arrow-left"></i> Back to Appointments</a>

    <div class="row">
        <div class="col-md-8 offset-md-2">
            <!-- Main Appointment Card -->
            <div class="card border-0 shadow-lg mb-4">
                <div class="card-header bg-primary text-white p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <h3 class="mb-0"><i class="bi bi-calendar-check"></i> Appointment #@Model.Id</h3>
                        <span class="badge bg-@GetStatusBg(Model.Status) fs-6">@Model.Status</span>
                    </div>
                </div>

                <div class="card-body p-4">
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <h5 class="mb-3"><i class="bi bi-person-circle"></i> Patient Information</h5>
                            <div class="info-box">
                                <p class="mb-2">
                                    <strong>Name:</strong><br />
                                    <span class="ms-3">@Model.PatientName</span>
                                </p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <h5 class="mb-3"><i class="bi bi-hospital"></i> Doctor Information</h5>
                            <div class="info-box">
                                <p class="mb-2">
                                    <strong>Name:</strong><br />
                                    <span class="ms-3">Dr. @Model.DoctorName</span>
                                </p>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <div class="row">
                        <div class="col-md-6">
                            <h5 class="mb-3"><i class="bi bi-clock"></i> Appointment Details</h5>
                            <div class="info-box">
                                <p class="mb-3">
                                    <strong>Date &amp; Time:</strong><br />
                                    <span class="ms-3">@Model.AppointmentDate.ToString("dddd, dd-MMMM-yyyy HH:mm")</span>
                                </p>
                                <p class="mb-0">
                                    <strong>Created:</strong><br />
                                    <span class="ms-3">@Model.CreatedAt.ToString("dd-MMM-yyyy HH:mm")</span>
                                </p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <h5 class="mb-3"><i class="bi bi-sticky"></i> Notes</h5>
                            <div class="info-box">
                                @if (!string.IsNullOrEmpty(Model.Notes))
                                {
                                    <p class="mb-0">@Model.Notes</p>
                                }
                                else
                                {
                                    <p class="mb-0 text-muted">No additional notes</p>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Prescription Card (if available) -->
            @if (prescription != null)
            {
                <div class="card border-0 shadow-lg mb-4">
                    <div class="card-header bg-success text-white p-4">
                        <h3 class="mb-0"><i class="bi bi-prescription"></i> Prescription</h3>
                    </div>
                    <div class="card-body p-4">
                        <div class="mb-4">
                            <h5 class="mb-2"><strong>Diagnosis:</strong></h5>
                            <p class="ms-3">@prescription.Diagnosis</p>
                        </div>

                        @if (!string.IsNullOrEmpty(prescription.Notes))
                        {
                            <div class="mb-4">
                                <h5 class="mb-2"><strong>Medical Notes:</strong></h5>
                                <p class="ms-3">@prescription.Notes</p>
                            </div>
                        }

                        @if (prescription.Medicines?.Count > 0)
                        {
                            <div class="mb-0">
                                <h5 class="mb-3"><strong><i class="bi bi-capsule"></i> Medicines</strong></h5>
                                <div class="row g-3">
                                    @foreach (var medicine in prescription.Medicines)
                                    {
                                        <div class="col-md-6">
                                            <div class="medicine-box">
                                                <h6 class="mb-2">@medicine.Name</h6>
                                                <p class="mb-1"><strong>Dosage:</strong> @medicine.Dosage</p>
                                                <p class="mb-1"><strong>Duration:</strong> @medicine.Duration</p>
                                                @if (!string.IsNullOrEmpty(medicine.Instructions))
                                                {
                                                    <p class="mb-0"><strong>Instructions:</strong> @medicine.Instructions</p>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-info text-center py-4 mb-4">
                    <p class="mb-0"><i class="bi bi-info-circle"></i> No prescription available for this appointment yet.</p>
                </div>
            }

            <!-- Bill Card -->
            @{
                var bill = await ViewContext.HttpContext.RequestServices.GetService<SmartHealthcare.MVC.Services.IApiService>()
                    .GetAsync<SmartHealthcare.Models.DTOs.BillDTO>($"bills/appointment/{Model.Id}", ViewContext.HttpContext.Session.GetString("Token"));
            }
            @if (bill != null)
            {
                <div class="card border-0 shadow-lg mb-4">
                    <div class="card-header bg-warning text-dark p-4">
                        <h3 class="mb-0"><i class="bi bi-receipt"></i> Bill</h3>
                    </div>
                    <div class="card-body p-4">
                        <div class="row">
                            <div class="col-md-6">
                                <p class="mb-2"><strong>Consultation Fee:</strong> $@bill.ConsultationFee.ToString("F2")</p>
                                <p class="mb-2"><strong>Medicine Charges:</strong> $@bill.MedicineCharges.ToString("F2")</p>
                                <p class="mb-2"><strong>Total Amount:</strong> $@bill.TotalAmount.ToString("F2")</p>
                                <p class="mb-2"><strong>Status:</strong> <span class="badge bg-@GetBillStatusBg(bill.PaymentStatus)">@bill.PaymentStatus</span></p>
                            </div>
                        </div>
                        <div class="mt-3">
                            <a asp-action="Details" asp-controller="Bills" asp-route-appointmentId="@Model.Id" class="btn btn-outline-primary">View Bill Details</a>
                        </div>
                    </div>
                </div>
            }
            else if (ViewBag.Role == "Admin" || ViewBag.Role == "Doctor")
            {
                <div class="card border-0 shadow-lg mb-4">
                    <div class="card-header bg-secondary text-white p-4">
                        <h3 class="mb-0"><i class="bi bi-receipt"></i> Bill</h3>
                    </div>
                    <div class="card-body p-4 text-center">
                        <p class="mb-3">No bill has been created for this appointment yet.</p>
                        <a asp-action="Create" asp-controller="Bills" asp-route-appointmentId="@Model.Id" class="btn btn-primary">Create Bill</a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@functions {
    private string GetStatusBg(string status)
    {
        return status?.ToLower() switch
        {
            "pending" => "warning",
            "completed" => "success",
            "cancelled" => "danger",
            _ => "secondary"
        };
    }

    private string GetBillStatusBg(string status)
    {
        return status?.ToLower() switch
        {
            "unpaid" => "warning",
            "paid" => "success",
            "cancelled" => "danger",
            _ => "secondary"
        };
    }
}

<style>
    body {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        font-family: 'Inter', sans-serif;
    }

    .container {
        animation: fadeInUp 0.8s ease-out;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .btn-outline-secondary {
        border: 2px solid rgba(255, 255, 255, 0.3);
        color: white;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        transition: all 0.3s ease;
        border-radius: 25px;
        padding: 0.5rem 1.5rem;
    }

    .btn-outline-secondary:hover {
        background: rgba(255, 255, 255, 0.2);
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.2);
    }

    .card {
        border-radius: 20px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
        backdrop-filter: blur(10px);
        background: rgba(255, 255, 255, 0.95);
        border: none;
        overflow: hidden;
        transition: all 0.3s ease;
        animation: slideInScale 0.6s ease-out;
    }

    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 30px 60px rgba(0, 0, 0, 0.15);
    }

    @@keyframes slideInScale {
        from {
            opacity: 0;
            transform: scale(0.95) translateY(20px);
        }
        to {
            opacity: 1;
            transform: scale(1) translateY(0);
        }
    }

    .card-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        position: relative;
        overflow: hidden;
    }

    .card-header::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: linear-gradient(45deg, transparent, rgba(255, 255, 255, 0.1), transparent);
        animation: shimmer 3s infinite;
    }

    @@keyframes shimmer {
        0% { transform: translateX(-100%) translateY(-100%) rotate(45deg); }
        100% { transform: translateX(100%) translateY(100%) rotate(45deg); }
    }

    .card-header.bg-success {
        background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
    }

    .badge {
        background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 100%);
        border: none;
        padding: 0.5rem 1rem;
        border-radius: 20px;
        font-weight: 600;
        box-shadow: 0 4px 15px rgba(255, 154, 158, 0.3);
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.05); }
    }

    .info-box {
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.9) 0%, rgba(248, 250, 252, 0.9) 100%);
        padding: 1.5rem;
        border-radius: 15px;
        border-left: 5px solid #667eea;
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
        transition: all 0.3s ease;
        backdrop-filter: blur(10px);
    }

    .info-box:hover {
        transform: translateX(5px);
        box-shadow: 0 12px 35px rgba(0, 0, 0, 0.15);
    }

    .medicine-box {
        background: linear-gradient(135deg, rgba(25, 137, 84, 0.1) 0%, rgba(56, 239, 125, 0.1) 100%);
        padding: 1.5rem;
        border-radius: 15px;
        border-left: 5px solid #11998e;
        box-shadow: 0 8px 25px rgba(25, 137, 84, 0.1);
        transition: all 0.3s ease;
        backdrop-filter: blur(10px);
        animation: fadeIn 0.8s ease-out;
    }

    .medicine-box:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 35px rgba(25, 137, 84, 0.2);
    }

    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    .alert {
        background: linear-gradient(135deg, rgba(13, 110, 253, 0.1) 0%, rgba(13, 110, 253, 0.05) 100%);
        border: 1px solid rgba(13, 110, 253, 0.2);
        border-radius: 15px;
        color: #0d6efd;
        backdrop-filter: blur(10px);
        animation: slideIn 0.6s ease-out;
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateX(-30px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    hr {
        border: none;
        height: 2px;
        background: linear-gradient(90deg, transparent, #667eea, transparent);
        margin: 2rem 0;
    }

    h3, h5 {
        font-weight: 600;
        color: #2d3748;
    }

    .text-muted {
        color: #718096 !important;
    }

    @@media (max-width: 768px) {
        .container {
            padding: 1rem;
        }

        .card-body {
            padding: 1.5rem !important;
        }

        .info-box, .medicine-box {
            padding: 1rem;
        }

        .btn-outline-secondary {
            width: 100%;
            margin-bottom: 1rem;
        }
    }
</style>