@model SmartHealthcare.Models.DTOs.PatientDTO
@{
    ViewData["Title"] = "My Profile";
    var needsProfile = ViewBag.NeedsProfile as bool? ?? false;
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            
            @if (needsProfile)
            {
                <div class="card border-0 shadow-lg">
                    <div class="card-header bg-info text-white p-4">
                        <h3 class="mb-0"><i class="bi bi-person-plus"></i> Complete Your Profile</h3>
                    </div>
                    
                    <div class="card-body p-4">
                        <p class="text-muted mb-4">To book appointments and access our services, please complete your medical profile.</p>
                        
                        <form asp-action="CreateProfile" method="post" novalidate>
                            <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>
                            
                            <!-- Date of Birth -->
                            <div class="mb-4">
                                <label class="form-label fw-bold"><i class="bi bi-calendar-event"></i> Date of Birth *</label>
                                <input type="date" name="DateOfBirth" class="form-control form-control-lg" required />
                                <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                            </div>

                            <!-- Gender -->
                            <div class="mb-4">
                                <label class="form-label fw-bold"><i class="bi bi-person-fill"></i> Gender *</label>
                                <select name="Gender" class="form-select form-select-lg" required>
                                    <option value="" selected>-- Select Gender --</option>
                                    <option value="Male">Male</option>
                                    <option value="Female">Female</option>
                                    <option value="Other">Other</option>
                                </select>
                                <span asp-validation-for="Gender" class="text-danger small"></span>
                            </div>

                            <!-- Blood Group -->
                            <div class="mb-4">
                                <label class="form-label fw-bold"><i class="bi bi-droplet-fill"></i> Blood Group</label>
                                <input name="BloodGroup" class="form-control form-control-lg" placeholder="e.g., O+, A-, B+, AB+" />
                                <span asp-validation-for="BloodGroup" class="text-danger small"></span>
                            </div>

                            <!-- Address -->
                            <div class="mb-4">
                                <label class="form-label fw-bold"><i class="bi bi-geo-alt"></i> Address *</label>
                                <textarea name="Address" class="form-control form-control-lg" rows="3" placeholder="Enter your full address" required></textarea>
                                <span asp-validation-for="Address" class="text-danger small"></span>
                            </div>

                            <!-- Phone -->
                            <div class="mb-4">
                                <label class="form-label fw-bold"><i class="bi bi-telephone"></i> Phone Number *</label>
                                <input name="Phone" type="tel" class="form-control form-control-lg" placeholder="Your phone number" required />
                                <span asp-validation-for="Phone" class="text-danger small"></span>
                            </div>

                            <!-- Buttons -->
                            <div class="d-grid gap-2 d-sm-flex">
                                <button type="submit" class="btn btn-info btn-lg"><i class="bi bi-check-circle"></i> Create Profile</button>
                                <a href="@Url.Action("Index", "Dashboard")" class="btn btn-outline-secondary btn-lg"><i class="bi bi-x-circle"></i> Cancel</a>
                            </div>
                        </form>
                    </div>
                </div>
            }
            else
            {
                <div class="card border-0 shadow-lg">
                    <div class="card-header bg-success text-white p-4">
                        <h3 class="mb-0"><i class="bi bi-person-check"></i> Your Medical Profile</h3>
                    </div>
                    
                    <div class="card-body p-4">
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <div class="profile-section">
                                    <h6 class="text-muted mb-2"><i class="bi bi-person"></i> PERSONAL INFORMATION</h6>
                                    <hr class="my-2" />
                                    <p class="mb-2">
                                        <strong>Full Name:</strong><br />
                                        <span class="ms-3">@Model.FullName</span>
                                    </p>
                                    <p class="mb-0">
                                        <strong>Email:</strong><br />
                                        <span class="ms-3">@Model.Email</span>
                                    </p>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="profile-section">
                                    <h6 class="text-muted mb-2"><i class="bi bi-telephone"></i> CONTACT INFORMATION</h6>
                                    <hr class="my-2" />
                                    <p class="mb-2">
                                        <strong>Phone:</strong><br />
                                        <span class="ms-3">@Model.Phone</span>
                                    </p>
                                    <p class="mb-0">
                                        <strong>Address:</strong><br />
                                        <span class="ms-3">@Model.Address</span>
                                    </p>
                                </div>
                            </div>
                        </div>

                        <row class="mb-4">
                            <div class="col-md-6">
                                <div class="profile-section">
                                    <h6 class="text-muted mb-2"><i class="bi bi-calendar-event"></i> MEDICAL INFORMATION</h6>
                                    <hr class="my-2" />
                                    <p class="mb-2">
                                        <strong>Date of Birth:</strong><br />
                                        <span class="ms-3">@Model.DateOfBirth.ToString("dd-MMMM-yyyy")</span>
                                    </p>
                                    <p class="mb-0">
                                        <strong>Age:</strong><br />
                                        <span class="ms-3">@((DateTime.Now.Year - Model.DateOfBirth.Year)) years</span>
                                    </p>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="profile-section">
                                    <h6 class="text-muted mb-2"><i class="bi bi-droplet-fill"></i> HEALTH DETAILS</h6>
                                    <hr class="my-2" />
                                    <p class="mb-2">
                                        <strong>Gender:</strong><br />
                                        <span class="ms-3">@Model.Gender</span>
                                    </p>
                                    <p class="mb-0">
                                        <strong>Blood Group:</strong><br />
                                        <span class="ms-3">
                                            @if (!string.IsNullOrEmpty(Model.BloodGroup))
                                            {
                                                <span class="badge bg-danger">@Model.BloodGroup</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Not specified</span>
                                            }
                                        </span>
                                    </p>
                                </div>
                            </div>
                        </row>
                    </div>

                    <div class="card-footer bg-light p-4">
                        <div class="d-grid gap-2 d-sm-flex">
                            <a href="@Url.Action("Index", "Appointment")" class="btn btn-success btn-lg">
                                <i class="bi bi-calendar-check"></i> Book Appointment
                            </a>
                            <a href="@Url.Action("Index", "Doctor")" class="btn btn-info btn-lg">
                                <i class="bi bi-search"></i> Find a Doctor
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .card {
        border: none;
        border-radius: 2rem;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
        backdrop-filter: blur(20px);
        background: rgba(255, 255, 255, 0.95);
        overflow: hidden;
        transition: all 0.3s ease;
        animation: cardSlideIn 0.8s ease-out;
    }

    @@keyframes cardSlideIn {
        from {
            opacity: 0;
            transform: translateY(30px) scale(0.95);
        }
        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 30px 60px rgba(0, 0, 0, 0.15);
    }

    .card-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        padding: 2rem;
        position: relative;
    }

    .card-header::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
    }

    .card-header h3 {
        position: relative;
        z-index: 1;
        margin: 0;
        font-weight: 700;
        text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
    }

    .card-body {
        padding: 2.5rem;
    }

    .profile-section {
        background: linear-gradient(135deg, rgba(248, 250, 252, 0.8), rgba(241, 245, 249, 0.8));
        padding: 2rem;
        border-radius: 1.5rem;
        border-left: 4px solid #0d6efd;
        margin-bottom: 1.5rem;
        transition: all 0.3s ease;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.05);
        backdrop-filter: blur(10px);
    }

    .profile-section:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 30px rgba(0, 0, 0, 0.1);
    }

    .profile-section h6 {
        color: #4a5568;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 1rem;
        position: relative;
    }

    .profile-section h6::after {
        content: '';
        position: absolute;
        bottom: -5px;
        left: 0;
        width: 50px;
        height: 3px;
        background: linear-gradient(90deg, #0d6efd, #6610f2);
        border-radius: 2px;
    }

    .profile-section p {
        margin-bottom: 0.75rem;
        font-size: 1rem;
        line-height: 1.6;
    }

    .profile-section strong {
        color: #2d3748;
        font-weight: 600;
    }

    .badge {
        background: linear-gradient(135deg, #dc3545, #c82333) !important;
        border-radius: 2rem;
        padding: 0.5rem 1rem;
        font-weight: 600;
        box-shadow: 0 4px 10px rgba(220, 53, 69, 0.3);
    }

    .form-control, .form-select {
        border-radius: 1rem;
        border: 2px solid #e2e8f0;
        padding: 0.75rem 1rem;
        font-size: 1rem;
        transition: all 0.3s ease;
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(10px);
    }

    .form-control:focus, .form-select:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.15);
        transform: translateY(-2px);
    }

    .form-label {
        font-weight: 600;
        color: #374151;
        margin-bottom: 0.5rem;
        font-size: 0.95rem;
    }

    .btn {
        border-radius: 2rem;
        padding: 0.75rem 2rem;
        font-weight: 600;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .btn::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
        transition: left 0.5s;
    }

    .btn:hover::before {
        left: 100%;
    }

    .btn-info {
        background: linear-gradient(135deg, #0dcaf0, #0aa2c0);
        border: none;
        box-shadow: 0 8px 20px rgba(13, 202, 240, 0.3);
    }

    .btn-info:hover {
        background: linear-gradient(135deg, #0aa2c0, #0987a0);
        transform: translateY(-3px);
        box-shadow: 0 12px 30px rgba(13, 202, 240, 0.4);
    }

    .btn-outline-secondary {
        border: 2px solid #6c757d;
        color: #6c757d;
    }

    .btn-outline-secondary:hover {
        background: linear-gradient(135deg, #6c757d, #545b62);
        border-color: #6c757d;
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(108, 117, 125, 0.3);
    }

    .card-footer {
        background: linear-gradient(135deg, rgba(248, 250, 252, 0.9), rgba(241, 245, 249, 0.9));
        border-top: 1px solid rgba(0, 0, 0, 0.05);
        padding: 2rem;
    }

    .card-footer .btn {
        margin: 0 0.5rem;
    }

    .alert {
        border-radius: 1rem;
        border: none;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        backdrop-filter: blur(10px);
    }

    .alert-info {
        background: linear-gradient(135deg, #d1ecf1, #bee5eb);
        color: #0c5460;
    }

    /* Icon enhancements */
    .bi {
        filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.2));
        transition: all 0.3s ease;
    }

    .bi:hover {
        transform: scale(1.1);
    }

    /* Responsive adjustments */
    @@media (max-width: 768px) {
        .card-body, .card-header, .card-footer {
            padding: 1.5rem;
        }

        .profile-section {
            padding: 1.5rem;
        }

        .row .col-md-6 {
            margin-bottom: 1.5rem;
        }
    }
</style>