@model List<ECommerceSystem.Models.Order>

<h2>Orders</h2>

<a asp-action="Create" class="btn btn-success mb-3">Place New Order</a>

<table class="table">
    <tr>
        <th>Customer</th>
        <th>Date</th>
        <th>Status</th>
    </tr>

    @foreach (var order in Model)
    {
        <tr>
            <td>@order.Customer?.Name</td>
            <td>@order.OrderDate</td>
            <td>@order.ShippingDetail?.Status</td>
        </tr>
    }
</table>