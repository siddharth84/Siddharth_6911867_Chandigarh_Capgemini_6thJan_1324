@model ECommerceSystem.Models.Product

<h2>Add Product</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="All"></div>

    <input asp-for="Name" placeholder="Name" class="form-control mb-2" />
    <input asp-for="Price" placeholder="Price" class="form-control mb-2" />

    <select asp-for="CategoryId" asp-items="@(ViewBag.CategoryId as SelectList)" class="form-control mb-2">
        <option value="">Select Category</option>
    </select>

    <button class="btn btn-primary">Save</button>
</form>