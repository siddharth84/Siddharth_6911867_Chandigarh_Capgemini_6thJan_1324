@model List<ECommerceSystem.Models.ShippingDetail>

<h2>Shipping Details</h2>

<a asp-action="Create" class="btn btn-success mb-3">Add Shipping</a>

<table class="table">
    <tr>
        <th>Order</th>
        <th>Address</th>
        <th>Status</th>
        <th>Action</th>
    </tr>

    @foreach (var s in Model)
    {
        <tr>
            <td>@s.OrderId</td>
            <td>@s.Address</td>
            <td>@s.Status</td>
            <td>
                <a asp-action="Edit" asp-route-id="@s.ShippingDetailId" class="btn btn-warning btn-sm">Edit</a>
            </td>
        </tr>
    }
</table>